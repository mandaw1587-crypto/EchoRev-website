# ── SMTP Configuration ──────────────────────────────────────────
# Gmail: use App Password (not your regular password)
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password-here

# ── Sender Info ──────────────────────────────────────────────────
SENDER_NAME=Your Name
SENDER_TITLE=Founder, EchoRev AI Syndicate
SENDER_EMAIL=you@echorev.com
FROM_ADDRESS="EchoRev AI Syndicate <you@echorev.com>"

# ── Campaign Links ───────────────────────────────────────────────
BOOKING_LINK=https://calendly.com/your-link
WEBSITE_URL=https://echorev.com
UNSUBSCRIBE_URL=https://echorev.com/unsubscribe

# ── Campaign Settings ────────────────────────────────────────────
# Delay between emails in milliseconds (default: 3000ms = 3 seconds)
# Increase to reduce risk of spam flags (recommend 5000-15000ms)
EMAIL_DELAY_MS=5000

# Follow-up delay in days
FOLLOWUP_DELAY_DAYS=4

# Max emails per run (safety cap)
MAX_EMAILS_PER_RUN=50
